@prefix ex: <http://www.mytho-ontologist.org/Mythology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.mytho-ontologist.org/Mythology#>	a	owl:Ontology .

ex:MythoDomainEntity	a owl:Class .
ex:Hindu-Mythological-Characters	a	owl:Class ;
			rdfs:subClassOf ex:MythoDomainEntity .
ex:Marriage a owl:Class ;
    rdfs:subClassOf ex:MythoDomainEntity .
	
ex:Sex a owl:Class ;
    rdfs:subClassOf ex:MythoDomainEntity ;
    owl:equivalentClass [ a owl:Class ;
            owl:unionOf ( ex:Female ex:Male ) ] .

ex:Person	a	owl:Class;
	rdfs:subClassOf	ex:Hindu-Mythological-Characters;
    owl:disjointWith ex:Sex ;
    owl:equivalentClass [ a owl:Class ;
            owl:unionOf ( ex:Man ex:Woman ) ] .
			
ex:Man a owl:Class ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( ex:Person [ a owl:Restriction ;
                        owl:onProperty ex:hasSex ;
                        owl:someValuesFrom ex:Male ] ) ] .
						
ex:Woman a owl:Class ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( ex:Person [ a owl:Restriction ;
                        owl:onProperty ex:hasSex ;
                        owl:someValuesFrom ex:Female ] ) ] .
ex:Male a owl:Class ;
    rdfs:subClassOf ex:Sex .

ex:Female a owl:Class ;
    rdfs:subClassOf ex:Sex ;
    owl:disjointWith ex:Male .

ex:King	a	owl:Class;
			rdfs:subClassOf	ex:Hindu-Mythological-Characters.
ex:Queen	a	owl:Class;
			rdfs:subClassOf	ex:Hindu-Mythological-Characters.
ex:Maharaja	a	owl:Class;
			rdfs:subClassOf	ex:Hindu-Mythological-Characters.				
ex:Devotee	a	owl:Class;
			rdfs:subClassOf	ex:Hindu-Mythological-Characters.
ex:Emperor	a	owl:Class;
			rdfs:subClassOf	ex:Hindu-Mythological-Characters.			
######################################################	
