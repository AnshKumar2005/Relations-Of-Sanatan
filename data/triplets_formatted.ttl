###########################################
ex:hasFemalePartner a owl:ObjectProperty ;
    rdfs:range ex:Woman ;
    rdfs:domain ex:Marriage ;
    rdfs:subPropertyOf ex:hasPartner ;
    owl:inverseOf ex:isFemalePartnerIn .

ex:hasMalePartner a owl:ObjectProperty ;
    rdfs:range ex:Man ;
    rdfs:domain ex:Marriage ;
    rdfs:subPropertyOf ex:hasPartner ;
    owl:inverseOf ex:isMalePartnerIn .
	
ex:isFatherOf a owl:ObjectProperty .
ex:isMotherOf a owl:ObjectProperty .
ex:isBrotherOf a owl:ObjectProperty ;
    rdfs:domain ex:Man ;
    rdfs:range ex:Person ;
    rdfs:subPropertyOf ex:isSiblingOf .

ex:isSisterOf a owl:ObjectProperty ;
    rdfs:domain ex:Woman ;
    rdfs:range ex:Person ;
    rdfs:subPropertyOf ex:isSiblingOf .
	
ex:hasHusband a owl:ObjectProperty ;
    rdfs:range ex:Man ;
    rdfs:subPropertyOf ex:hasSpouse ;
    owl:propertyChainAxiom ( ex:isFemalePartnerIn ex:hasMalePartner ) .

ex:hasWife a owl:ObjectProperty ;
    rdfs:range ex:Woman ;
    rdfs:subPropertyOf ex:hasSpouse ;
    owl:propertyChainAxiom ( ex:isMalePartnerIn ex:hasFemalePartner ) .	
	
ex:isHusbandOf a owl:ObjectProperty ;
    owl:inverseOf ex:hasHusband .

ex:isWifeOf a owl:ObjectProperty ;
    owl:inverseOf ex:hasWife .

ex:isPartnerIn a owl:ObjectProperty .

ex:hasPartner a owl:ObjectProperty ;
    rdfs:domain ex:Marriage ;
    rdfs:range ex:Person ;
    owl:inverseOf ex:isPartnerIn .

ex:isSpouseOf a owl:ObjectProperty .

ex:hasSpouse a owl:ObjectProperty ;
    owl:inverseOf ex:isSpouseOf .

ex:isFemalePartnerIn a owl:ObjectProperty .

ex:isMalePartnerIn a owl:ObjectProperty .

ex:isSiblingOf a owl:ObjectProperty,
        owl:SymmetricProperty,
        owl:TransitiveProperty ;
    rdfs:subPropertyOf ex:isBloodrelationOf ;
    owl:propertyChainAxiom ( ex:hasParent ex:isParentOf ) .

ex:hasChild a owl:ObjectProperty .

ex:isChildOf a owl:ObjectProperty ;
    owl:inverseOf ex:hasChild .

ex:hasDaughter a owl:ObjectProperty ;
    rdfs:subPropertyOf ex:hasChild .

ex:hasSon a owl:ObjectProperty ;
    rdfs:subPropertyOf ex:hasChild .

ex:isDaughterOf a owl:ObjectProperty ;
    rdfs:subPropertyOf ex:isChildOf ;
    owl:inverseOf ex:hasDaughter .

ex:isSonOf a owl:ObjectProperty ;
    rdfs:subPropertyOf ex:isChildOf ;
	rdfs:domain ex:Man ;
    rdfs:range ex:Person ;
    owl:inverseOf ex:hasSon .

ex:hasFather a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Man ;
    rdfs:subPropertyOf ex:hasParent ;
    owl:inverseOf ex:isFatherOf .

ex:hasMother a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Woman ;
    rdfs:subPropertyOf ex:hasParent ;
    owl:inverseOf ex:isMotherOf .

ex:hasParent a owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person ;
    rdfs:subPropertyOf ex:hasAncestor ;
    owl:equivalentProperty ex:isChildOf ;
    owl:inverseOf ex:isParentOf .

ex:isParentOf a owl:ObjectProperty .

ex:hasSex a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Sex .

ex:isAncestorOf a owl:ObjectProperty ;
    owl:inverseOf ex:hasAncestor .

ex:hasRelation a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person .

ex:isBloodrelationOf a owl:ObjectProperty ;
    rdfs:subPropertyOf ex:hasRelation .

ex:hasAncestor a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:subPropertyOf ex:hasRelation .

ex:hasUncle a owl:ObjectProperty ;
    owl:inverseOf ex:isUncleOf .

ex:isUncleOf a owl:ObjectProperty ;
    rdfs:domain ex:Man ;
    rdfs:range ex:Person ;
    owl:propertyChainAxiom ( ex:isBrotherOf ex:isParentOf ) .

ex:hasGreatUncle a owl:ObjectProperty ;
    owl:inverseOf ex:isGreatUncleOf .

ex:isGreatUncleOf a owl:ObjectProperty ;
    rdfs:domain ex:Man ;
    rdfs:range ex:Person ;
    owl:propertyChainAxiom ( ex:isBrotherOf ex:isGrandParentOf ) .

ex:hasAunt a owl:ObjectProperty ;
    owl:inverseOf ex:isAuntOf .

ex:isAuntOf a owl:ObjectProperty ;
    rdfs:domain ex:Woman ;
    rdfs:range ex:Person ;
    owl:propertyChainAxiom ( ex:isSisterOf ex:isParentOf ) .

ex:hasGreatAunt a owl:ObjectProperty ;
    owl:inverseOf ex:isGreatAuntOf .

ex:isGreatAuntOf a owl:ObjectProperty ;
    rdfs:domain ex:Woman ;
    rdfs:range ex:Person ;
    owl:propertyChainAxiom ( ex:isSisterOf ex:isGrandParentOf ) .

ex:isCousinOf a owl:ObjectProperty ;
    rdfs:subPropertyOf ex:isBloodrelationOf .

ex:isFirstCousinOf a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:subPropertyOf ex:isCousinOf ;
    owl:propertyChainAxiom ( ex:hasParent ex:isSiblingOf ex:isParentOf ) .

ex:isSecondCousinOf a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:subPropertyOf ex:isCousinOf ;
    owl:propertyChainAxiom ( ex:hasGrandParent ex:isSiblingOf ex:isGrandParentOf ) .

ex:isThirdCousinOf a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:subPropertyOf ex:isCousinOf ;
    owl:propertyChainAxiom ( ex:hasGreatGrandParent ex:isSiblingOf ex:isGreatGrandParentOf ) .

ex:isGrandfatherOf a owl:ObjectProperty ;
    owl:inverseOf ex:hasGrandfather .

ex:isGrandmotherOf a owl:ObjectProperty ;
    owl:inverseOf ex:hasGrandmother .

ex:isGrandParentOf a owl:ObjectProperty ;
    owl:inverseOf ex:hasGrandParent .

ex:hasGrandfather a owl:ObjectProperty ;
    rdfs:range ex:Man ;
    rdfs:subPropertyOf ex:hasGrandParent ;
    owl:propertyChainAxiom ( ex:hasParent ex:hasFather ) .

ex:hasGrandmother a owl:ObjectProperty ;
    rdfs:range ex:Woman ;
    rdfs:subPropertyOf ex:hasGrandParent ;
    owl:propertyChainAxiom ( ex:hasParent ex:hasMother ) .

ex:hasGrandParent a owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person ;
    rdfs:subPropertyOf ex:hasAncestor ;
    owl:propertyChainAxiom ( ex:hasParent ex:hasParent ) .

ex:isGreatGrandfatherOf a owl:ObjectProperty ;
    owl:inverseOf ex:hasGreatGrandfather .

ex:isGreatGrandmotherOf a owl:ObjectProperty ;
    owl:inverseOf ex:hasGreatGrandmother .

ex:isGreatGrandParentOf a owl:ObjectProperty ;
    owl:inverseOf ex:hasGreatGrandParent .

ex:hasGreatGrandfather a owl:ObjectProperty ;
    rdfs:range ex:Man ;
    rdfs:subPropertyOf ex:hasGreatGrandParent ;
    owl:propertyChainAxiom ( ex:hasParent ex:hasGrandfather ) .

ex:hasGreatGrandmother a owl:ObjectProperty ;
    rdfs:range ex:Woman ;
    rdfs:subPropertyOf ex:hasGreatGrandParent ;
    owl:propertyChainAxiom ( ex:hasParent ex:hasGrandmother ) .

ex:hasGreatGrandParent a owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person ;
    rdfs:subPropertyOf ex:hasAncestor ;
    owl:propertyChainAxiom ( ex:hasParent ex:hasParent ex:hasParent ) .

ex:hasBrotherInLaw a owl:ObjectProperty ;
    owl:inverseOf ex:isBrotherInLawOf .
	
ex:isBrotherInLawOf a owl:ObjectProperty ;
    rdfs:domain ex:Man ;
    rdfs:range ex:Person .

ex:hasCarrier a owl:ObjectProperty ;
    owl:inverseOf ex:isCarrierOf .
	
ex:isCarrierOf a owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person .    

ex:hasDescendant a owl:ObjectProperty ;
    owl:inverseOf ex:isDescendantOf .
	
ex:isDescendantOf a owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person . 

ex:hasDevotee a owl:ObjectProperty ;
    owl:inverseOf ex:isDevoteeOf .
	
ex:isDevoteeOf a owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person .
	
ex:hasDisciple a owl:ObjectProperty ;
    owl:inverseOf ex:isDiscipleOf .
	
ex:isDiscipleOf a owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person .

ex:hasEnemy a owl:ObjectProperty ;
    owl:inverseOf ex:isEnemyOf .
	
ex:isEnemyOf a owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person .


ex:hasFatherInLaw a owl:ObjectProperty ;
    owl:inverseOf ex:isFatherInLawOf .
	
ex:isFatherInLawOf a owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person .
	
ex:hasFriend a owl:ObjectProperty ;
    owl:inverseOf ex:isFriendOf .
	
ex:isFriendOf a owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person .

ex:hasGrandSon a owl:ObjectProperty ;
    owl:inverseOf ex:isGrandSonOf .
	
ex:isGrandSonOf a owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person .

ex:hasGreatGrandSon a owl:ObjectProperty ;
    owl:inverseOf ex:isGreatGrandSonOf .
	
ex:isGreatGrandSonOf a owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person .	

ex:hasKiller a owl:ObjectProperty ;
    owl:inverseOf ex:isKillerOf .
	
ex:isKillerOf a owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person .

ex:isKnownAs a owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person .
	
ex:hasMaster a owl:ObjectProperty ;
    owl:inverseOf ex:isMasterOf .
	
ex:isMasterOf a owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person .	
	
ex:hasServant a owl:ObjectProperty ;
    owl:inverseOf ex:isServantOf .
	
ex:isServantOf a owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person .

ex:hasSpiritualMaster a owl:ObjectProperty ;
    owl:inverseOf ex:isSpiritualMasterOf .
	
ex:isSpiritualMasterOf a owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person .
